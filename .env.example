# --- Horde configuration ---
# Copy to .env and adjust for your TrueNAS server.

# UID/GID of the TrueNAS user that owns the media dataset. Find it in
# TrueNAS under Credentials > Local Users (or run `id <user>` on the shell).
# The container writes downloads and the database as this user so files are
# readable/writable over SMB and not owned by root.
PUID=1000
PGID=1000

# Host path to your ZFS dataset for media. Create this dataset first, e.g.
# /mnt/tank/media/youtube_archive
DOWNLOADS_PATH=/mnt/tank/media/youtube_archive

# Host path for persistent app data (SQLite DB + cached thumbnails). This
# must survive container restarts.
DATA_PATH=/opt/dockge/horde/data

# How often (seconds) the fallback poller rescans the media folder for
# manually dropped files. ZFS network mounts sometimes drop inotify events,
# so this guarantees new files are picked up.
SCAN_INTERVAL_SEC=60

# Max simultaneous download workers. Default is 1 to reduce bot-detection
# triggers from YouTube when fetching multiple videos at once.
MAX_DOWNLOAD_CONCURRENCY=1
